{
  "name": "@phosphor-icons/svelte",
  "version": "2.0.8",
  "description": "Phosphor Icons for Svelte — auto-generated from @phosphor-icons/core",
  "type": "module",
  "svelte": "./src/lib/index.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./src/lib/index.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/lib"
  ],
  "scripts": {
    "assemble": "tsx scripts/assemble.ts",
    "build": "svelte-kit sync && svelte-package -i src/lib",
    "dev": "vite dev",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write \"src/**/*.{ts,svelte}\" \"scripts/**/*.ts\""
  },
  "devDependencies": {
    "@phosphor-icons/core": "^2.1.1",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "chalk": "^5.6.2",
    "fast-xml-parser": "^5.8.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "peerDependencies": {
    "svelte": ">=4.0.0"
  },
  "keywords": [
    "svelte",
    "icons",
    "phosphor",
    "svg",
    "ui",
    "components"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/phosphor-svelte"
  }
}
